# =============================================================
# JualAkun — Environment Variables
# Copy file ini ke .env.local (frontend) dan .env (backend)
# JANGAN commit file .env ke git
# =============================================================

# -------------------------------------------------------------
# SUPABASE
# -------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role key: HANYA di backend (Cloudflare Workers), JANGAN expose ke frontend

# -------------------------------------------------------------
# MIDTRANS PAYMENT GATEWAY
# -------------------------------------------------------------
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
MIDTRANS_IS_PRODUCTION=false
# Ganti SB-Mid- dengan Mid- saat production
# Webhook URL: https://api.jualakun.id/payment/webhook

# -------------------------------------------------------------
# ENCRYPTION (untuk credentials akun di database)
# -------------------------------------------------------------
ENCRYPTION_KEY=32-karakter-random-string-di-sini!!
# Generate: openssl rand -hex 32
# WAJIB sama antara backend dan saat decrypt credentials

# -------------------------------------------------------------
# NOTIFIKASI — WHATSAPP (Fonnte)
# -------------------------------------------------------------
FONNTE_API_KEY=xxxxxxxxxxxxxxxxxxxx
FONNTE_DEVICE=628xxxxxxxxxxxxxxx
# Device adalah nomor WA yang sudah terhubung ke Fonnte

# -------------------------------------------------------------
# NOTIFIKASI — EMAIL (Resend)
# -------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@jualakun.id
RESEND_FROM_NAME=JualAkun

# -------------------------------------------------------------
# ADMIN NOTIFICATIONS
# -------------------------------------------------------------
ADMIN_WHATSAPP_NUMBER=628xxxxxxxxxxxxxxx
# Nomor WA admin yang terima alert stok kritis & tiket baru

# -------------------------------------------------------------
# CLOUDFLARE WORKERS (Backend)
# -------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------------
# FRONTEND (Next.js — prefix NEXT_PUBLIC_ = exposed ke browser)
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_API_URL=https://api.jualakun.id
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_SITE_URL=https://jualakun.id

# -------------------------------------------------------------
# OPTIONAL — Analytics & Monitoring
# -------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
# SENTRY_DSN=https://xxxx@sentry.io/xxxx
