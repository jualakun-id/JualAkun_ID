# =============================================================
# JualAkun — Environment Variables
# Copy file ini ke .env.local (frontend) dan .env (backend)
# JANGAN commit file .env ke git
# =============================================================

# -------------------------------------------------------------
# SUPABASE
# -------------------------------------------------------------
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
# Service role key: HANYA di backend (Cloudflare Workers), JANGAN expose ke frontend

# -------------------------------------------------------------
# QRIS MANUAL PAYMENT (GoPay Saya merchant)
# -------------------------------------------------------------
# Decode QRIS Statis PNG dari app GoPay Saya pakai https://zxing.org/w/decode.jspx
# Format: "00020101021126610014COM.GO-JEK.WWW...6304XXXX"
QRIS_STATIC_PAYLOAD=00020101021126610014COM.GO-JEK.WWW...

# -------------------------------------------------------------
# PUBLIC URLs
# -------------------------------------------------------------
PUBLIC_API_URL=https://api.jualakun.id
PUBLIC_SITE_URL=https://jualakun.id

# -------------------------------------------------------------
# ENCRYPTION (untuk credentials akun di database)
# -------------------------------------------------------------
ENCRYPTION_KEY=32-karakter-random-string-di-sini!!
# Generate: openssl rand -hex 32
# WAJIB sama antara backend dan saat decrypt credentials

# -------------------------------------------------------------
# NOTIFIKASI — WHATSAPP (WAHA — self-hosted WhatsApp HTTP API)
# -------------------------------------------------------------
WAHA_BASE_URL=https://waha.example.com
WAHA_API_KEY=xxxxxxxxxxxxxxxxxxxx
WAHA_SESSION=default
# Base URL: instance WAHA Anda (Core/Plus/NoWeb engine)
# Session: nama session yang sudah login & aktif (default: "default")
# Endpoint yang dipakai: POST {WAHA_BASE_URL}/api/sendText
# chatId format: 628xxx@c.us (auto-normalized di NotificationService)

# -------------------------------------------------------------
# NOTIFIKASI — EMAIL (Resend)
# -------------------------------------------------------------
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@jualakun.id
RESEND_FROM_NAME=JualAkun

# -------------------------------------------------------------
# ADMIN NOTIFICATIONS
# -------------------------------------------------------------
ADMIN_WHATSAPP_NUMBER=628xxxxxxxxxxxxxxx
# Nomor WA admin yang terima alert stok kritis & tiket baru

# -------------------------------------------------------------
# CLOUDFLARE WORKERS (Backend)
# -------------------------------------------------------------
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_API_TOKEN=xxxxxxxxxxxxxxxxxxxx

# -------------------------------------------------------------
# FRONTEND (Next.js — prefix NEXT_PUBLIC_ = exposed ke browser)
# -------------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
NEXT_PUBLIC_API_URL=https://api.jualakun.id
NEXT_PUBLIC_SITE_URL=https://jualakun.id

# -------------------------------------------------------------
# OPTIONAL — Analytics & Monitoring
# -------------------------------------------------------------
# NEXT_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxx
# SENTRY_DSN=https://xxxx@sentry.io/xxxx
