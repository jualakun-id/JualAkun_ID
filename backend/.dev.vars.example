# Copy to .dev.vars (auto-loaded by `wrangler dev`)
# JANGAN commit .dev.vars
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
ENCRYPTION_KEY=32-karakter-random-string-di-sini
PUBLIC_API_URL=http://localhost:8787
PUBLIC_SITE_URL=http://localhost:3000
WAHA_BASE_URL=https://waha.example.com
WAHA_API_KEY=xxxxxxxxxxxxxxxxxxxx
WAHA_SESSION=default
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@jualakun.id
ADMIN_WHATSAPP_NUMBER=628xxxxxxxxxxxxxxx
# WhatsApp group ID untuk admin alerts (selain admin personal number).
# Dapatkan via WAHA API: GET /api/{session}/groups → cari subject "Notif Penjualan"
# Format: "<id>@g.us" misal "120363426756060932@g.us"
ADMIN_WA_GROUP_ID=
# WhatsApp group ID dedicated untuk stock digest 4x/hari (06:00, 12:00, 18:00, 00:00 WIB).
# Beda dari ADMIN_WA_GROUP_ID supaya admin DM tidak ke-spam digest non-kritis.
# Group "Jualakun.id Community" — cari via GET /api/{session}/groups.
WAHA_STOCK_DIGEST_GROUP_ID=
ADMIN_EMAIL=admin@jualakun.id
# QRIS Statis dari GoPay Saya — decode QR image pakai zxing.org untuk dapat string
QRIS_STATIC_PAYLOAD=00020101021126620014ID.CO.QRIS.WWW...
CRON_SECRET=ganti-dengan-random-32-char
